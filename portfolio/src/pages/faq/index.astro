---
import HomeLayout from '../../layouts/HomeLayout.astro';
---

<HomeLayout title="FAQ - Yuvi">
  <section class="page-header">
    <div class="container">
      <h1 class="spaced-title">F &nbsp; &nbsp; &nbsp; &nbsp; A &nbsp; &nbsp; &nbsp; &nbsp; Q</h1>
    </div>
  </section>

  <section class="faq-section">
    <div class="container">
      <div class="faq-list">
        
        <div class="faq-item active">
          <button class="faq-question">
            <span>What technologies do you specialize in?</span>
            <span class="icon">▲</span>
          </button>
          <div class="faq-answer" style="max-height: none;">
            <p>
              I specialize in modern JavaScript/TypeScript architectures including **React**, **Next.js**, **Astro**, **Svelte**, and **Node.js**. 
              My database preference lies in **PostgreSQL** and **Supabase**. On the design side, I focus on premium typography, CSS layouts, and Figma.
            </p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            <span>What is your typical project timeline?</span>
            <span class="icon">▼</span>
          </button>
          <div class="faq-answer">
            <p>
              Small-to-medium web platforms typically take **3 to 6 weeks** from kickoff to production launch. 
              Larger application architectures, headless e-commerce integrations, or design systems usually span **2 to 3 months**.
            </p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            <span>Are you open to full-time employment or freelance consulting?</span>
            <span class="icon">▼</span>
          </button>
          <div class="faq-answer">
            <p>
              Yes, I am available for full-time product roles, freelance contracts, and design systems consulting. 
              Let's connect through the interactive project planner page to discuss options.
            </p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            <span>Where are you based and how do you handle remote communication?</span>
            <span class="icon">▼</span>
          </button>
          <div class="faq-answer">
            <p>
              I work fully remote, collaborating with teams globally. I rely heavily on clean asynchronous workflows using Slack, 
              Notion, Linear, GitHub, and Figma to maintain transparency and alignment across time zones.
            </p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            <span>How do you structure project pricing?</span>
            <span class="icon">▼</span>
          </button>
          <div class="faq-answer">
            <p>
              I generally price projects using a fixed-scope model (best for defined milestones) or a weekly retainer (best for agile collaboration). 
              Submit a brief through the planner to receive a personalized estimate.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>
</HomeLayout>

<script>
  const faqItems = document.querySelectorAll('.faq-item');
  
  faqItems.forEach(item => {
    const button = item.querySelector('.faq-question');
    const answer = item.querySelector('.faq-answer');
    
    button.addEventListener('click', () => {
      const isOpen = item.classList.contains('active');
      
      // Close all items
      faqItems.forEach(i => {
        i.classList.remove('active');
        i.querySelector('.faq-answer').style.maxHeight = '0';
        i.querySelector('.icon').textContent = '▼';
      });
      
      // Open clicked item if it wasn't already open
      if (!isOpen) {
        item.classList.add('active');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        button.querySelector('.icon').textContent = '▲';
      }
    });
  });
</script>

<style>
  .page-header {
    padding: var(--spacing-xxl) 0 var(--spacing-xl);
    text-align: center;
  }

  .spaced-title {
    font-family: var(--font-serif);
    font-size: 6rem;
    font-weight: 800;
    margin-bottom: 0;
    color: var(--color-text);
  }

  .faq-section {
    padding: 0 0 var(--spacing-xxl);
  }

  .faq-list {
    max-width: 800px;
    margin: 0 auto;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
    margin-bottom: var(--spacing-xs);
    background-color: var(--color-bg);
    transition: background-color 0.2s ease;
  }

  .faq-item.active {
    background-color: var(--color-secondary);
    border-radius: var(--border-radius-md);
    padding: 0 var(--spacing-md);
    border-bottom: none;
  }

  .faq-question {
    width: 100%;
    text-align: left;
    padding: var(--spacing-lg) 0;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .faq-question .icon {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-muted);
    transition: transform 0.2s ease;
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .faq-answer p {
    padding-bottom: var(--spacing-lg);
    color: var(--color-muted);
    font-size: 1.1rem;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .spaced-title {
      font-size: 3.5rem;
    }

    .faq-question {
      font-size: 1.1rem;
    }
  }
</style>
