---
import HomeLayout from '../layouts/HomeLayout.astro';
---

<HomeLayout title="Switch-Lit - Home">
  <section class="hero">
    <div class="container">
      <h1>SWITCH‑LIT</h1>
      <p class="tagline">Collaborative Stories for the Collective Imagination</p>
      <p class="description">
        A creative writing platform designed for turn-based collaborative fiction, poetry, and prose. 
        Each work becomes an imaginative conversation between any two creative writers.
      </p>
      <div class="cta-buttons">
        <a href="/start-a-story" class="btn btn-primary">Start a Story</a>
        <a href="/library" class="btn btn-secondary">Browse Library</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>Welcome to Switch-Lit.</h2>
      <p>
        We're thrilled to meet you here – at the beginning of an extraordinary journey into 
        the evolution of collaborative fiction as a catalytic structure for our time.
      </p>
      <p>
        Our mission is universal: to manifest the collective imagination of creative writers 
        and literary artists through the connective power of collaborative fiction, poetry, and prose.
      </p>
      <p>
        We envision Switch-Lit as an infinite space in a remote corner of the Internet where 
        the forces of your imagination can freely meet and connect with other writers towards 
        the creation of new worlds, unimaginable by a single mind.
      </p>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <h2>Featured Stories</h2>
      <div class="featured-grid">
        <article class="story-card">
          <h3>cupid's arrow hit us perfect</h3>
          <p class="authors">written by: ... and AULANDC©</p>
        </article>
        <article class="story-card">
          <h3>Grievances</h3>
          <p class="authors">written by AYUSHAM TONI© and EMILY CHERCHILL©</p>
        </article>
        <article class="story-card">
          <h3>Infinity</h3>
          <p class="authors">written by ZIN© and MIAO©</p>
        </article>
        <article class="story-card">
          <h3>Haunting from the Shadows</h3>
          <p class="authors">written by KAIN© and ZIN©</p>
        </article>
        <article class="story-card">
          <h3>Temporary Diversion</h3>
          <p class="authors">written by JULIA GARIE© and INSPOIS©</p>
        </article>
      </div>
      <div class="view-all">
        <a href="/library" class="btn btn-secondary">View All Stories</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2>How It Works</h2>
      <div class="steps-grid">
        <div class="step">
          <h3>1. Start a Story</h3>
          <p>Begin your collaborative journey by setting up your story parameters and inviting a writing partner.</p>
        </div>
        <div class="step">
          <h3>2. Take Turns</h3>
          <p>Alternate chapters with your partner, each building upon the other's creative vision.</p>
        </div>
        <div class="step">
          <h3>3. Publish</h3>
          <p>Share your completed collaborative work in our public library for others to discover.</p>
        </div>
      </div>
    </div>
  </section>
</HomeLayout>

<style>
  .hero {
    padding: calc(var(--spacing-xl) * 2) 0;
    text-align: center;
    background: linear-gradient(135deg, rgba(26, 26, 26, 0.05) 0%, rgba(245, 245, 245, 0.5) 100%);
  }

  .hero h1 {
    font-size: 3.5rem;
    margin-bottom: var(--spacing-md);
    letter-spacing: -0.02em;
  }

  .hero .tagline {
    font-size: 1.5rem;
    color: var(--color-muted);
    margin-bottom: var(--spacing-md);
  }

  .hero .description {
    font-size: 1.125rem;
    color: var(--color-muted);
    margin-bottom: var(--spacing-lg);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta-buttons {
    display: flex;
    gap: var(--spacing-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  .section {
    padding: var(--spacing-xxl) 0;
  }

  .section-alt {
    background-color: var(--color-secondary);
  }

  .section h2 {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }

  .section p {
    max-width: 800px;
    margin: 0 auto var(--spacing-md);
    color: var(--color-muted);
    text-align: center;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  .story-card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-md);
    padding: var(--spacing-lg);
    transition: transform 0.2s ease;
  }

  .story-card:hover {
    transform: translateY(-4px);
  }

  .story-card h3 {
    font-style: italic;
    margin-bottom: var(--spacing-sm);
    font-size: 1.125rem;
  }

  .story-card .authors {
    color: var(--color-muted);
    font-size: 0.875rem;
  }

  .view-all {
    text-align: center;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--spacing-xl);
    margin-top: var(--spacing-xl);
  }

  .step {
    text-align: center;
    padding: var(--spacing-lg);
  }

  .step h3 {
    margin-bottom: var(--spacing-sm);
  }

  .step p {
    color: var(--color-muted);
    font-size: 1rem;
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2.5rem;
    }

    .hero .tagline {
      font-size: 1.25rem;
    }

    .section h2 {
      font-size: 1.5rem;
    }
  }
</style>
